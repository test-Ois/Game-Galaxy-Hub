# ============================================================
# Game Galaxy Hub — Environment Variables
# ============================================================

# === Frontend (Vercel) ===
# Set this on Vercel Dashboard → Settings → Environment Variables
# Points to your Render backend URL (no trailing slash)
# NEXT_PUBLIC_SOCKET_URL=https://game-galaxy-hub-backend.onrender.com

# === Backend (Render) ===
# Set these on Render Dashboard → Environment Variables
# PORT is auto-set by Render, no need to configure manually
# PORT=4000
# CORS_ORIGIN=https://game-galaxy-hub.vercel.app
